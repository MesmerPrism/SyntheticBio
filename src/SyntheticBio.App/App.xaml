<Application x:Class="SyntheticBio.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Color x:Key="AppPaperColor">#FFFDF9</Color>
        <Color x:Key="SurfaceLightColor">#F6F1E9</Color>
        <Color x:Key="SurfaceTintColor">#FBF7EF</Color>
        <Color x:Key="CarbonColor">#1F2226</Color>
        <Color x:Key="GraphiteColor">#5B636F</Color>
        <Color x:Key="GridGrayColor">#CFC8BE</Color>
        <Color x:Key="PanelEdgeColor">#D7CFC4</Color>
        <Color x:Key="FocusBlueColor">#258ACB</Color>
        <Color x:Key="SignalRedColor">#C94E3A</Color>
        <Color x:Key="HazardYellowColor">#9E7714</Color>
        <Color x:Key="SafetyOrangeColor">#C86E1C</Color>
        <Color x:Key="TelemetryCyanColor">#1E6E9E</Color>
        <Color x:Key="TelemetryGreenColor">#628F37</Color>

        <SolidColorBrush x:Key="AppPaperBrush" Color="{StaticResource AppPaperColor}" />
        <SolidColorBrush x:Key="SurfaceLightBrush" Color="{StaticResource SurfaceLightColor}" />
        <SolidColorBrush x:Key="SurfaceTintBrush" Color="{StaticResource SurfaceTintColor}" />
        <SolidColorBrush x:Key="CarbonBrush" Color="{StaticResource CarbonColor}" />
        <SolidColorBrush x:Key="GraphiteBrush" Color="{StaticResource GraphiteColor}" />
        <SolidColorBrush x:Key="GridBrush" Color="{StaticResource GridGrayColor}" />
        <SolidColorBrush x:Key="PanelEdgeBrush" Color="{StaticResource PanelEdgeColor}" />
        <SolidColorBrush x:Key="FocusBlueBrush" Color="{StaticResource FocusBlueColor}" />
        <SolidColorBrush x:Key="SignalRedBrush" Color="{StaticResource SignalRedColor}" />
        <SolidColorBrush x:Key="HazardYellowBrush" Color="{StaticResource HazardYellowColor}" />
        <SolidColorBrush x:Key="SafetyOrangeBrush" Color="{StaticResource SafetyOrangeColor}" />
        <SolidColorBrush x:Key="TelemetryCyanBrush" Color="{StaticResource TelemetryCyanColor}" />
        <SolidColorBrush x:Key="TelemetryGreenBrush" Color="{StaticResource TelemetryGreenColor}" />

        <FontFamily x:Key="UiFont">Bahnschrift Condensed</FontFamily>
        <FontFamily x:Key="MonoFont">Consolas</FontFamily>

        <Style TargetType="{x:Type Window}">
            <Setter Property="Background" Value="{StaticResource AppPaperBrush}" />
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style TargetType="{x:Type GridSplitter}">
            <Setter Property="Background" Value="{StaticResource GridBrush}" />
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="Background" Value="{StaticResource AppPaperBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontFamily="{TemplateBinding FontFamily}"
                                              TextElement.FontSize="{TemplateBinding FontSize}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource FocusBlueBrush}" />
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceTintBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource FocusBlueBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceLightBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource FocusBlueBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceLightBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource GridBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{StaticResource AppPaperBrush}" />
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource FocusBlueBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceLightBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource GridBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="{StaticResource AppPaperBrush}" />
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Application.Resources>
</Application>
